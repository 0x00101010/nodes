# shared env vars
COMPOSE_PROJECT_NAME=base-sepolia
NETWORK=sepolia
CL_DNS="base-sepolia-node"
EL_DNS="base-sepolia-reth"
PROMETHEUS_DNS="base-sepolia-prometheus"

# -------------------------------------
# Base node build config (github.com/base/base v0.9.0)
# -------------------------------------
BASE_REPO=https://github.com/base/base.git
BASE_COMMIT=0276bb4eb9b3ee37703bd818c8df71e3d31594fb # v0.9.0
RUST_VERSION=1.93.1

# -------------------------------------
# Snapshot init config
# -------------------------------------
# SNAPSHOT_MODE: "skip" (use existing data) or "download" (wipe el_data and pull fresh snapshot)
SNAPSHOT_MODE=skip
SNAPSHOT_BASE_URL=https://sepolia-reth-pruned-snapshots.base.org
# SNAPSHOT_VERSION: "latest" resolves via $SNAPSHOT_BASE_URL/latest, or pass an explicit filename
SNAPSHOT_VERSION=latest
SNAPSHOT_ARIA2_CONNECTIONS=16

# -------------------------------------
# reth (base-reth-node) env vars
# -------------------------------------
RETH_CHAIN=base-sepolia
RETH_GCMODE=full
RETH_SEQUENCER_HTTP=https://sepolia-sequencer.base.org
RETH_LOG_LEVEL=debug
RETH_ALLOWED_APIS=web3,debug,eth,txpool,net,admin,rpc

EL_RPC_PORT=6000
EL_WS_PORT=6001
EL_AUTHRPC_PORT=6002
EL_METRICS_PORT=6003
EL_P2P_PORT=30305
EL_DISCOVERY_V5_PORT=30306

# -------------------------------------
# base-consensus env vars (BASE_NODE_* auto-bound by clap)
# -------------------------------------
BASE_NODE_NETWORK=84532
BASE_NODE_MODE=validator
BASE_NODE_L1_TRUST_RPC=true
BASE_NODE_L1_ETH_RPC="${SEPOLIA_L1_ETH_RPC}"
BASE_NODE_L1_BEACON="${SEPOLIA_L1_BEACON_RPC}"
BASE_NODE_L2_ENGINE_AUTH=/config/jwtsecret
BASE_NODE_L2_ENGINE_RPC="http://${EL_DNS}:${EL_AUTHRPC_PORT}"
BASE_NODE_RPC_ADDR=0.0.0.0
BASE_NODE_RPC_PORT=6020
BASE_NODE_VERIFIER_L1_CONFS=4

# base-consensus metrics config
BASE_NODE_METRICS_ADDR=0.0.0.0
BASE_NODE_METRICS_PORT=6010

# base-consensus p2p env vars
BASE_NODE_P2P_BOOTNODES=enr:-J24QNz9lbrKbN4iSmmjtnr7SjUMk4zB7f1krHZcTZx-JRKZd0kA2gjufUROD6T3sOWDVDnFJRvqBBo62zuF-hYCohOGAYiOoEyEgmlkgnY0gmlwhAPniryHb3BzdGFja4OFQgCJc2VjcDI1NmsxoQKNVFlCxh_B-716tTs-h1vMzZkSs1FTu_OYTNjgufplG4N0Y3CCJAaDdWRwgiQG,enr:-J24QH-f1wt99sfpHy4c0QJM-NfmsIfmlLAMMcgZCUEgKG_BBYFc6FwYgaMJMQN5dsRBJApIok0jFn-9CS842lGpLmqGAYiOoDRAgmlkgnY0gmlwhLhIgb2Hb3BzdGFja4OFQgCJc2VjcDI1NmsxoQJ9FTIv8B9myn1MWaC_2lJ-sMoeCDkusCsk4BYHjjCq04N0Y3CCJAaDdWRwgiQG,enr:-J24QDXyyxvQYsd0yfsN0cRr1lZ1N11zGTplMNlW4xNEc7LkPXh0NAJ9iSOVdRO95GPYAIc6xmyoCCG6_0JxdL3a0zaGAYiOoAjFgmlkgnY0gmlwhAPckbGHb3BzdGFja4OFQgCJc2VjcDI1NmsxoQJwoS7tzwxqXSyFL7g0JM-KWVbgvjfB8JA__T7yY_cYboN0Y3CCJAaDdWRwgiQG,enr:-J24QHmGyBwUZXIcsGYMaUqGGSl4CFdx9Tozu-vQCn5bHIQbR7On7dZbU61vYvfrJr30t0iahSqhc64J46MnUO2JvQaGAYiOoCKKgmlkgnY0gmlwhAPnCzSHb3BzdGFja4OFQgCJc2VjcDI1NmsxoQINc4fSijfbNIiGhcgvwjsjxVFJHUstK9L1T8OTKUjgloN0Y3CCJAaDdWRwgiQG,enr:-J24QG3ypT4xSu0gjb5PABCmVxZqBjVw9ca7pvsI8jl4KATYAnxBmfkaIuEqy9sKvDHKuNCsy57WwK9wTt2aQgcaDDyGAYiOoGAXgmlkgnY0gmlwhDbGmZaHb3BzdGFja4OFQgCJc2VjcDI1NmsxoQIeAK_--tcLEiu7HvoUlbV52MspE0uCocsx1f_rYvRenIN0Y3CCJAaDdWRwgiQG
