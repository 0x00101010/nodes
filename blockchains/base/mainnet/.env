# shared env vars
COMPOSE_PROJECT_NAME=base-mainnet
NETWORK=mainnet
CL_DNS="base-mainnet-node"
EL_DNS="base-mainnet-reth"
PROMETHEUS_DNS="base-mainnet-prometheus"

# -------------------------------------
# Base node build config (github.com/base/base proofs v2)
# -------------------------------------
BASE_REPO=https://github.com/base/base.git
BASE_COMMIT=370e207d25ba82c44d1e70424cec1c0ddc7e0919 # proofs v2
RUST_VERSION=1.93.1

# -------------------------------------
# Snapshot init config
# -------------------------------------
# SNAPSHOT_MODE: "skip" (use existing data) or "download" (fresh pull wipes el_data; interrupted pull resumes)
SNAPSHOT_MODE=download
SNAPSHOT_BASE_URL=https://mainnet-reth-pruned-snapshots.base.org
# SNAPSHOT_VERSION: "latest" resolves via $SNAPSHOT_BASE_URL/latest, or pass an explicit filename
# SNAPSHOT_VERSION=latest
SNAPSHOT_VERSION=base-mainnet-pruned-reth-1779439990.tar.zst
SNAPSHOT_ARIA2_CONNECTIONS=16

# -------------------------------------
# reth (base-reth-node) env vars
# -------------------------------------
RETH_CHAIN=base
RETH_GCMODE=full
RETH_SEQUENCER_HTTP=https://mainnet-sequencer.base.org
RETH_LOG_LEVEL=info
RETH_ALLOWED_APIS=web3,debug,eth,txpool,net,admin,rpc
RETH_PROOFS_HISTORY_INIT=true
RETH_PROOFS_HISTORY_STORAGE_PATH=/data/proofs-history
RETH_PROOFS_HISTORY_WINDOW=1296000
RETH_PROOFS_HISTORY_PRUNE_INTERVAL=15s
RETH_PROOFS_HISTORY_VERIFICATION_INTERVAL=1000

EL_RPC_PORT=5000
EL_WS_PORT=5001
EL_AUTHRPC_PORT=5002
EL_METRICS_PORT=5003
EL_P2P_PORT=30304
EL_DISCOVERY_V5_PORT=30305

# -------------------------------------
# base-consensus env vars (BASE_NODE_* auto-bound by clap)
# -------------------------------------
BASE_NODE_COMMAND=follow
BASE_NODE_NETWORK=8453
BASE_NODE_MODE=validator
BASE_NODE_L1_TRUST_RPC=true
BASE_NODE_L1_ETH_RPC="${MAINNET_L1_ETH_RPC}"
BASE_NODE_L1_BEACON="${MAINNET_L1_BEACON_RPC}"
BASE_NODE_SOURCE_L2_RPC=https://mainnet.base.org
BASE_NODE_L2_RPC_URL="http://${EL_DNS}:${EL_RPC_PORT}"
BASE_NODE_L2_ENGINE_AUTH=/config/jwtsecret
BASE_NODE_L2_ENGINE_RPC="http://${EL_DNS}:${EL_AUTHRPC_PORT}"
BASE_NODE_PROOFS=true
BASE_NODE_PROOFS_MAX_BLOCKS_AHEAD=16
BASE_NODE_RPC_ADDR=0.0.0.0
BASE_NODE_RPC_PORT=5020
BASE_NODE_VERIFIER_L1_CONFS=4

# base-consensus metrics config
BASE_NODE_METRICS_ADDR=0.0.0.0
BASE_NODE_METRICS_PORT=5010

# base-consensus p2p env vars
BASE_NODE_P2P_ADVERTISE_IP=0x00101010.tplinkdns.com # can be DNS
BASE_NODE_P2P_LISTEN_IP=0.0.0.0
BASE_NODE_P2P_LISTEN_TCP_PORT=9222
BASE_NODE_P2P_LISTEN_UDP_PORT=9222

# prometheus config
PROMETHEUS_PORT=9081
PROMETHEUS_LOG_LEVEL=debug
PROMETHEUS_DATA_RETENTION_TIME=32d
PROMETHEUS_TEMPLATE_CONFIG_FILE=base-config-template.yml
